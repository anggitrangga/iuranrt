// Prisma schema for Iuran RT App

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Model User (Admin, Bendahara, Warga)
model User {
  id        String   @id @default(cuid())
  nama      String
  email     String   @unique
  password  String
  role      String   @default("warga") // admin, bendahara, warga
  idWarga   String?  // link ke warga (kalau role=warga)
  aktif    Boolean  @default(true)

  warga     Warga?   @relation(fields: [idWarga], references: [id])
  @@unique([idWarga])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// Model Warga (Kepala Keluarga)
model Warga {
  id           String    @id @default(cuid())
  nama         String
  nik          String    @unique
  alamat       String
  telepon      String?
  status       String    @default("aktif")
  tanggalMasuk DateTime  @default(now())

  tagihan      Tagihan[]
  user         User?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("warga")
}

// Model Tagihan
model Tagihan {
  id                String    @id @default(cuid())
  idWarga           String
  jenis             String    // "Uang Sampah", "Uang Keamanan"
  jumlah            Int
  bulan             String
  tanggalJatuhTempo DateTime
  status            String    @default("belum_bayar") // lunas, belum_bayar, terlambat
  tanggalBayar      DateTime?
  metodeBayar       String?
  keterangan        String?

  warga             Warga     @relation(fields: [idWarga], references: [id])

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([idWarga])
  @@index([status])
  @@index([bulan])
  @@map("tagihan")
}

// Model Transaksi
model Transaksi {
  id          String    @id @default(cuid())
  idWarga     String?
  namaWarga   String?
  jenis       String    // "Pemasukan", "Pengeluaran"
  kategori    String
  jumlah      Int
  tanggal     DateTime
  keterangan  String?
  metodeBayar String?
  inputBy     String?   // user_id yang input

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([jenis])
  @@index([tanggal])
  @@map("transaksi")
}

// Model Konfigurasi
model Konfigurasi {
  id              String   @id @default(cuid())
  namaRt          String   @default("RT 03")
  alamatRt        String?
  iuranSampah     Int      @default(50000)
  iuranKeamanan   Int      @default(10000)
  batasPembayaran Int      @default(15) // tanggal 15 setiap bulan

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("konfigurasi")
}