// Prisma schema for Iuran RT App

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Model Warga (Kepala Keluarga)
model Warga {
  id           String    @id @default(cuid())
  nama         String
  nik          String    @unique
  alamat       String
  telepon      String?
  status       String    @default("aktif")
  tanggalMasuk DateTime  @default(now())

  tagihan      Tagihan[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("warga")
}

// Model Tagihan
model Tagihan {
  id                String    @id @default(cuid())
  idWarga           String
  jenis             String
  jumlah            Int
  bulan             String
  tanggalJatuhTempo DateTime
  status            String    @default("belum_bayar")
  tanggalBayar      DateTime?
  metodeBayar       String?

  warga             Warga     @relation(fields: [idWarga], references: [id])

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([idWarga])
  @@index([status])
  @@index([bulan])
  @@map("tagihan")
}

// Model Transaksi
model Transaksi {
  id          String    @id @default(cuid())
  idWarga     String?
  namaWarga   String?
  jenis       String
  kategori    String
  jumlah      Int
  tanggal     DateTime
  keterangan  String?
  metodeBayar String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([jenis])
  @@index([tanggal])
  @@map("transaksi")
}

// Model User
model User {
  id       String   @id @default(cuid())
  nama     String
  email    String   @unique
  password String
  role     String   @default("user")
  idWarga  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// Model Konfigurasi
model Konfigurasi {
  id             String   @id @default(cuid())
  namaRt         String   @default("RT 03")
  iuranSampah    Int      @default(50000)
  iuranKeamanan Int      @default(10000)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("konfigurasi")
}
